# Image tags used by Docker Compose. The server script builds from source by default.
BACKEND_IMAGE=ghcr.io/no-end-story/no-end-story-backend:latest
FRONTEND_IMAGE=ghcr.io/no-end-story/no-end-story-frontend:latest

# Public web entry. Point hyjkblj.online DNS A record to the server IP.
APP_DOMAIN=hyjkblj.online
HTTP_BIND=0.0.0.0
HTTP_PORT=80

# PostgreSQL is bound to localhost by default. Do not expose it publicly.
DB_BIND=127.0.0.1
DB_PORT=5432
DB_NAME=noendstory
DB_USER=noendstory
POSTGRES_PASSWORD=

# Redis is bound to localhost by default. Set REDIS_PASSWORD in production.
REDIS_BIND=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# App behavior
ENV=prod
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://hyjkblj.online,https://hyjkblj.online
EMBEDDING_MODEL=text2vec-chinese
IMAGE_SAVE_ENABLED=true
TTS_PROVIDER=volcengine

# AI keys. Fill only the providers you use.
OPENAI_API_KEY=

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-flash
DASHSCOPE_TTS_MODEL=sambert-zhichu-v1

VOLCENGINE_ARK_API_KEY=
VOLCENGINE_REGION=cn-beijing
LLM_TEXT_MODEL=deepseek-r1-250528
VOLCENGINE_TEXT_MODEL=
VOLCENGINE_IMAGE_MODEL=doubao-seedream-4-0-250828
VOLCENGINE_IMAGE_SIZE=2K
VECTORENGINE_API_KEY=
VECTORENGINE_BASE_URL=https://api.vectorengine.ai
VECTORENGINE_IMAGE_MODEL=gpt-image-2
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_SECRET_KEY=
VOLCENGINE_TTS_MODEL=seed-tts-2.0
VOLCENGINE_TTS_RESOURCE_ID=volc.tts.default
VOLCENGINE_TTS_WEBSOCKET_URL=wss://openspeech.bytedance.com/api/v3/tts/bidirection
VOLCENGINE_TTS_USE_WEBSOCKET=false
VOLCENGINE_TTS_ENABLE_TIMESTAMP=false
VOLCENGINE_TTS_ENABLE_CACHE=true
VOLCENGINE_TTS_ENABLE_EMOTION=true

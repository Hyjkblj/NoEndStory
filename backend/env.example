# 应用配置
APP_NAME=No End Story API
APP_VERSION=0.1.0
APP_ENV=development
APP_SECRET_KEY=your-secret-key-change-in-production
DEBUG=true

# PostgreSQL 数据库配置（结构化数据）
DATABASE_URL=postgresql://user:password@localhost/noendstory

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Assistant IDs（在初始化时自动创建）
DIRECTOR_ASSISTANT_ID=
WRITER_ASSISTANT_ID=

# Chroma 配置（向量数据库 - 本地部署）
CHROMA_DB_PATH=./chroma_db

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

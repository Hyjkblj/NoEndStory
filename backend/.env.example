# ============================================
# Environment
# ============================================
# Options: dev, prod, test
ENV=dev

# ============================================
# Database
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=noendstory
DB_USER=postgres
DB_PASSWORD=

# ============================================
# Vector / Embedding
# ============================================
# VECTOR_DB_PATH=
# Options: default, text2vec-chinese, m3e-base, bge-small-zh-v1.5, paraphrase-multilingual
EMBEDDING_MODEL=text2vec-chinese

# ============================================
# AI Provider Keys
# ============================================
OPENAI_API_KEY=

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-flash
DASHSCOPE_TTS_MODEL=sambert-zhichu-v1

ZHIPU_API_KEY=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ============================================
# Volcengine (recommended)
# ============================================
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_REGION=cn-beijing

# Unified text model switch (preferred)
LLM_TEXT_MODEL=deepseek-r1-250528
# Legacy key kept for backward compatibility
VOLCENGINE_TEXT_MODEL=

VOLCENGINE_IMAGE_MODEL=doubao-seedream-4-0-250828
VOLCENGINE_IMAGE_SIZE=2K

# TTS
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_SECRET_KEY=
VOLCENGINE_TTS_MODEL=seed-tts-2.0
VOLCENGINE_TTS_RESOURCE_ID=volc.tts.default

# Optional WebSocket TTS
VOLCENGINE_TTS_WEBSOCKET_URL=wss://openspeech.bytedance.com/api/v3/tts/bidirection
VOLCENGINE_TTS_USE_WEBSOCKET=false

# TTS feature flags
VOLCENGINE_TTS_ENABLE_TIMESTAMP=false
VOLCENGINE_TTS_ENABLE_CACHE=true
VOLCENGINE_TTS_ENABLE_EMOTION=true

# ============================================
# TTS Provider
# ============================================
# Options: volcengine, dashscope, edge-tts
TTS_PROVIDER=volcengine

# ============================================
# Optional local model (Ollama)
# ============================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen:7b

# ============================================
# Optional game tuning
# ============================================
# GAME_MAX_EVENTS=3
# GAME_TOTAL_EVENTS=5

# ============================================
# Image output
# ============================================
IMAGE_SAVE_DIR=./images/characters
SCENE_IMAGE_SAVE_DIR=./images/scenes
SMALL_SCENE_IMAGE_SAVE_DIR=./images/smallscenes
COMPOSITE_IMAGE_SAVE_DIR=./images/composite
IMAGE_SAVE_ENABLED=true

# ============================================
# CORS (required in production)
# ============================================
# ALLOWED_ORIGINS=https://example.com,https://www.example.com

# ============================================
# Logging
# ============================================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Options: plain, json (json recommended for production)
LOG_FORMAT=plain

# ============================================
# Security (W4)
# ============================================
# Rate limiting
RATE_LIMIT_DEFAULT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=3600
GUEST_FREE_PLAYS=3

# Cost guard
COST_LIMIT_PER_IP_HOURLY=2.0
COST_LIMIT_PER_IP_DAILY=5.0

# ============================================
# Agent Engine (W6)
# ============================================
# USE_NOS_AGENT_ENGINE=false

# ============================================
# Observability (W11)
# ============================================
# HEALTH_FULL_CHECK=false

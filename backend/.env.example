# ============================================
# 环境配置
# ============================================
# 可选值: dev, prod, test
ENV=dev

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=noendstory
DB_USER=postgres
DB_PASSWORD=

# ============================================
# 向量数据库配置
# ============================================
# 向量数据库路径（可选，默认：项目根目录/vector_db）
# VECTOR_DB_PATH=

# Embedding模型配置
# 可选值: default, text2vec-chinese, m3e-base, bge-small-zh-v1.5, paraphrase-multilingual
EMBEDDING_MODEL=text2vec-chinese

# ============================================
# AI模型配置（至少配置一个）
# ============================================

# OpenAI配置（可选）
# OPENAI_API_KEY=

# 阿里云DashScope配置（可选）
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen-flash
# DASHSCOPE_TTS_MODEL=sambert-zhichu-v1

# 智谱AI配置（可选）
# ZHIPU_API_KEY=

# 百度文心一言配置（可选）
# BAIDU_API_KEY=
# BAIDU_SECRET_KEY=

# ============================================
# 火山引擎配置（推荐）
# ============================================

# ARK API Key（用于文本生成和图片生成）
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_REGION=cn-beijing

# 文本生成模型
VOLCENGINE_TEXT_MODEL=deepseek-v3-1-terminus

# 图片生成模型
VOLCENGINE_IMAGE_MODEL=doubao-seedream-4-0-250828
VOLCENGINE_IMAGE_SIZE=2K

# TTS语音合成配置（必需，如果使用火山引擎TTS）
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_SECRET_KEY=
VOLCENGINE_TTS_MODEL=seed-tts-2.0
VOLCENGINE_TTS_RESOURCE_ID=volc.tts.default

# WebSocket TTS配置（可选）
VOLCENGINE_TTS_WEBSOCKET_URL=wss://openspeech.bytedance.com/api/v3/tts/bidirection
VOLCENGINE_TTS_USE_WEBSOCKET=false

# TTS高级功能配置
VOLCENGINE_TTS_ENABLE_TIMESTAMP=false
VOLCENGINE_TTS_ENABLE_CACHE=true
VOLCENGINE_TTS_ENABLE_EMOTION=true

# ============================================
# TTS提供商选择
# ============================================
# 可选值: volcengine, dashscope, edge-tts
TTS_PROVIDER=volcengine

# ============================================
# 本地模型配置（Ollama）
# ============================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen:7b

# ============================================
# 游戏配置
# ============================================
# GAME_MAX_EVENTS=3
# GAME_TOTAL_EVENTS=5

# ============================================
# 图片保存配置
# ============================================
IMAGE_SAVE_DIR=./images/characters
SCENE_IMAGE_SAVE_DIR=./images/scenes
SMALL_SCENE_IMAGE_SAVE_DIR=./images/smallscenes
COMPOSITE_IMAGE_SAVE_DIR=./images/composite
IMAGE_SAVE_ENABLED=true

# ============================================
# CORS配置（生产环境必需）
# ============================================
# 生产环境必须设置，多个域名用逗号分隔
# 示例: ALLOWED_ORIGINS=https://example.com,https://www.example.com
# ALLOWED_ORIGINS=

# ============================================
# 日志配置
# ============================================
# 可选值: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

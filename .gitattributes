# 行尾符统一配置（Windows 项目）
# 所有文本文件使用 CRLF（Windows 标准）
* text=auto eol=crlf

# 源代码文件明确使用 CRLF
*.py text eol=crlf
*.ts text eol=crlf
*.tsx text eol=crlf
*.js text eol=crlf
*.jsx text eol=crlf
*.json text eol=crlf
*.css text eol=crlf
*.html text eol=crlf
*.md text eol=crlf
*.txt text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf
*.xml text eol=crlf
*.sql text eol=crlf
*.sh text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# 配置文件
*.gitignore text eol=crlf
*.gitattributes text eol=crlf
.editorconfig text eol=crlf
.env text eol=crlf
.env.* text eol=crlf

# 二进制文件不处理行尾符
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# 数据库文件
*.db binary
*.sqlite binary
*.sqlite3 binary

# 向量数据库文件
vector_db/** binary

# 编译产物
*.pyc binary
*.pyo binary
*.pyd binary
*.class binary
*.jar binary
*.war binary

# 压缩文件
*.7z binary
*.rar binary
*.gz binary

# 其他二进制文件
*.bin binary
*.dat binary

